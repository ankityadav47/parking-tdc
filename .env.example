# =========================================================================
# ParkSpot Environment Configuration Example
# =========================================================================

# -------------------------------------------------------------------------
# API Server Configuration
# -------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------------------------------------------
# Replace with your local or cloud PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/parkspot?schema=public"

# -------------------------------------------------------------------------
# Redis Configuration (BullMQ Background Jobs)
# -------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -------------------------------------------------------------------------
# Authentication (JWT)
# -------------------------------------------------------------------------
JWT_SECRET="super-secret-key-change-me-in-production"
JWT_EXPIRATION="7d"

# -------------------------------------------------------------------------
# Razorpay Integration (Payments)
# -------------------------------------------------------------------------
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# -------------------------------------------------------------------------
# Google Maps Integration (Frontend)
# -------------------------------------------------------------------------
# Vite automatically exposes variables prefixed with VITE_ to the frontend
VITE_GOOGLE_MAPS_API_KEY="AIzaSytest"

# -------------------------------------------------------------------------
# Frontend API Base URLs
# -------------------------------------------------------------------------
# For Local Development:
VITE_API_BASE_URL="http://localhost:4000/api/v1"
