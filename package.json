{
  "name": "parkspot",
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.0",
  "private": true,
  "description": "ParkSpot — Look, Book, Park. A two-sided parking marketplace.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter api build",
    "build:hostinger": "npx pnpm@9.12.0 install && npx pnpm@9.12.0 run build:api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api prisma db seed",
    "db:studio": "pnpm --filter api prisma studio",
    "db:generate": "pnpm --filter api prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
